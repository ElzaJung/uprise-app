# Provider selection: "openai" or "anthropic" (default: openai)
MODEL_PROVIDER=openai

# Optional model override (defaults: gpt-4o for openai, claude-sonnet-4-6 for anthropic)
# MODEL_NAME=gpt-4o
# MODEL_NAME=claude-opus-4-6

# API keys — only the key for the selected provider is required
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

PORT=3000